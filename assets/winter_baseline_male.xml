<mujoco model="Humanoid">
  <option timestep="0.005"/>
  <compiler inertiafromgeom="true"/>

  <visual>
    <map force="0.1" zfar="30"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global offwidth="2560" offheight="1440" elevation="-20" azimuth="120"/>
  </visual>

  <statistic center="0 0 0.7" extent="2.0"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
    <texture name="body" type="cube" builtin="flat" mark="cross" width="128" height="128" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" markrgb="1 1 1"/>
    <material name="body" texture="body" texuniform="true" rgba="0.8 0.6 .4 1"/>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
  </asset>

  <default>
    <motor ctrlrange="-1 1" ctrllimited="true"/>
    <default class="body">
      <geom type="capsule" condim="1" friction=".7" solimp=".9 .99 .003" solref=".015 1" material="body" group="1"/>
      <default class="foot">
        <geom condim="6" friction="1 0.05 0.0001"/>
      </default>
      <joint type="hinge" damping=".2" stiffness="1" armature=".001" limited="true" solimplimit="0 .99 .01"/>
      <default class="mtp">
        <joint pos="0 0 0" axis="0 1 0" range="-20 60" stiffness="20" damping="2"/>
      </default>
      <default class="joint_big">
        <joint damping="5" stiffness="10"/>
        <default class="hip_x"><joint range="-30 10"/></default>
        <default class="hip_z"><joint range="-60 35"/></default>
        <default class="hip_y"><joint axis="0 1 0" range="-150 20"/></default>
        <default class="joint_big_stiff"><joint stiffness="20"/></default>
      </default>
      <default class="knee"><joint pos="0 0 0" axis="0 -1 0" range="-160 2"/></default>
      <default class="ankle">
        <joint range="-50 50"/>
        <default class="ankle_y"><joint pos="0 0 0" axis="0 1 0" stiffness="6"/></default>
        <default class="ankle_x"><joint pos="0 0 0" stiffness="3"/></default>
      </default>
      <default class="shoulder"><joint range="-85 60"/></default>
      <default class="elbow"><joint range="-100 50" stiffness="0"/></default>
    </default>
  </default>

  <worldbody>
    <geom name="floor" size="0 0 .05" type="plane" material="grid" condim="3"/>
    <light name="spotlight" mode="targetbodycom" target="torso" diffuse=".8 .8 .8" specular="0.3 0.3 0.3" pos="0 -6 4" cutoff="30"/>
    <light name="top" pos="0 0 2" mode="trackcom"/>
    
    <body name="torso" pos="0 0 1.332" childclass="body">
      <camera name="back" pos="-3 0 1" xyaxes="0 -1 0 1 0 2" mode="trackcom"/>
      <camera name="side" pos="0 -3 1" xyaxes="1 0 0 0 1 2" mode="trackcom"/>
      <freejoint name="root"/>
      
      <!-- TRUNK (Interpolated): Winter specifies trunk as 0.497M (37.27kg).
           Tassa uses 4 lateral capsules of L=0.14m. 
           Solving the cubic volume root for 9.32kg per capsule yields r=0.104m. -->
      <geom name="torso" fromto="0 -.07 0 0 .07 0" size=".104"/>
      <geom name="waist_upper" fromto="-.01 -.06 -.12 -.01 .06 -.12" size=".104"/>
      
      <!-- HEAD (Winter): 0.081M (6.07kg) -> Sphere radius = 0.113m -->
      <body name="head" pos="0 0 .207">
        <geom name="head" type="sphere" size=".113"/>
        <camera name="egocentric" pos=".113 0 0" xyaxes="0 -1 0 .1 0 1" fovy="80"/>
      </body>
      
      <body name="waist_lower" pos="-.01 0 -.283">
        <geom name="waist_lower" fromto="0 -.06 0 0 .06 0" size=".104"/>
        <joint name="abdomen_z" pos="0 0 .065" axis="0 0 1" range="-45 45" class="joint_big_stiff"/>
        <joint name="abdomen_y" pos="0 0 .065" axis="0 1 0" range="-75 30" class="joint_big"/>
        
        <body name="pelvis" pos="0 0 -.180">
          <joint name="abdomen_x" pos="0 0 .1" axis="1 0 0" range="-35 35" class="joint_big"/>
          <geom name="butt" fromto="-.02 -.07 0 -.02 .07 0" size=".104"/>
          
          <body name="thigh_right" pos="0 -.1 -.044">
            <joint name="hip_x_right" axis="1 0 0" class="hip_x"/>
            <joint name="hip_z_right" axis="0 0 1" class="hip_z"/>
            <joint name="hip_y_right" class="hip_y"/>
            <!-- THIGH (Winter): 0.100M (7.50kg), L=0.429m -> Cubic root r=0.068m -->
            <geom name="thigh_right" fromto="0 0 0  0 0 -0.429" size=".068"/>
            <body name="shin_right" pos="0 0 -0.429">
              <joint name="knee_right" class="knee"/>
              <!-- SHIN (Winter): 0.046M (3.49kg), L=0.430m -> Cubic root r=0.048m. 
                   Collision disabled (contype/conaffinity=0) to prevent floor clipping. -->
              <geom name="shin_right" fromto="0 0 0  0 0 -0.430" size=".048" contype="0" conaffinity="0"/>
              <body name="foot_right" pos="0 0 -0.430">
                <joint name="ankle_y_right" class="ankle_y"/>
                <joint name="ankle_x_right" class="ankle_x" axis="1 0 .5"/>
                <!-- FOOT (Heel/Midfoot): 70% of 0.266m target length -->
                <geom name="foot1_right" class="foot" fromto="-.05 -.01 0 .098 -.03 0" size=".027"/>
                <geom name="foot2_right" class="foot" fromto="-.05 .01 0 .098 .03 0" size=".027"/>
                <body name="toe_right" pos="0.098 0 0">
                  <joint name="mtp_right" class="mtp"/>
                  <geom name="toe1_right" class="foot" fromto="0 -.03 0 .064 -.03 0" size=".027"/>
                  <geom name="toe2_right" class="foot" fromto="0 .03 0 .064 .03 0" size=".027"/>
                </body>
              </body>
            </body>
          </body>
          
          <body name="thigh_left" pos="0 .1 -.044">
            <joint name="hip_x_left" axis="-1 0 0" class="hip_x"/>
            <joint name="hip_z_left" axis="0 0 -1" class="hip_z"/>
            <joint name="hip_y_left" class="hip_y"/>
            <geom name="thigh_left" fromto="0 0 0  0 0 -0.429" size=".068"/>
            <body name="shin_left" pos="0 0 -0.429">
              <joint name="knee_left" class="knee"/>
              <geom name="shin_left" fromto="0 0 0  0 0 -0.430" size=".048" contype="0" conaffinity="0"/>
              <body name="foot_left" pos="0 0 -0.430">
                <joint name="ankle_y_left" class="ankle_y"/>
                <joint name="ankle_x_left" class="ankle_x" axis="-1 0 -.5"/>
                <!-- FOOT (Heel/Midfoot): 70% of 0.266m target length -->
                <geom name="foot1_left" class="foot" fromto="-.05 -.01 0 .098 -.03 0" size=".027"/>
                <geom name="foot2_left" class="foot" fromto="-.05 .01 0 .098 .03 0" size=".027"/>
                <body name="toe_left" pos="0.098 0 0">
                  <joint name="mtp_left" class="mtp"/>
                  <geom name="toe1_left" class="foot" fromto="0 -.03 0 .064 -.03 0" size=".027"/>
                  <geom name="toe2_left" class="foot" fromto="0 .03 0 .064 .03 0" size=".027"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
      
      <body name="upper_arm_right" pos="0 -.17 .06">
        <joint name="shoulder1_right" axis="1 0 0" range="-90 90"/>
        <joint name="shoulder2_right" axis="0 0 1" range="-85 60"/>
        <joint name="shoulder3_right" axis="0 1 0" range="-90 90"/>
        <!-- UPPER ARM (Winter): 0.028M (2.10kg), L=0.325m -> Cubic root r=0.042m -->
        <geom name="upper_arm_right" fromto="0 0 0  0 -0.325 0" size=".042"/>
        <body name="lower_arm_right" pos="0 -0.325 0">
          <joint name="elbow_right" axis="0 0 1" range="0 130"/>
          <!-- FOREARM (Winter): 0.016M (1.20kg), L=0.255m -> Cubic root r=0.036m -->
          <geom name="lower_arm_right" fromto="0 0 0  0 -0.255 0" size=".036"/>
          <body name="hand_right" pos="0 -0.255 0">
            <geom name="hand_right" type="sphere" size=".040"/>
          </body>
        </body>
      </body>
      
      <body name="upper_arm_left" pos="0 .17 .06">
        <joint name="shoulder1_left" axis="-1 0 0" range="-90 90"/>
        <joint name="shoulder2_left" axis="0 0 -1" range="-85 60"/>
        <joint name="shoulder3_left" axis="0 -1 0" range="-90 90"/>
        <geom name="upper_arm_left" fromto="0 0 0  0 0.325 0" size=".042"/>
        <body name="lower_arm_left" pos="0 0.325 0">
          <joint name="elbow_left" axis="0 0 -1" range="0 130"/>
          <geom name="lower_arm_left" fromto="0 0 0  0 0.255 0" size=".036"/>
          <body name="hand_left" pos="0 0.255 0">
            <geom name="hand_left" type="sphere" size=".040"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <contact>
    <exclude body1="waist_lower" body2="thigh_right"/>
    <exclude body1="waist_lower" body2="thigh_left"/>
  </contact>

  <tendon>
    <fixed name="hamstring_right" limited="true" range="-0.3 2">
      <joint joint="hip_y_right" coef=".5"/>
      <joint joint="knee_right" coef="-.5"/>
    </fixed>
    <fixed name="hamstring_left" limited="true" range="-0.3 2">
      <joint joint="hip_y_left" coef=".5"/>
      <joint joint="knee_left" coef="-.5"/>
    </fixed>
  </tendon>

  <actuator>
    <motor name="abdomen_z"       gear="40"  joint="abdomen_z"/>
    <motor name="abdomen_y"       gear="40"  joint="abdomen_y"/>
    <motor name="abdomen_x"       gear="40"  joint="abdomen_x"/>
    <motor name="hip_x_right"     gear="40"  joint="hip_x_right"/>
    <motor name="hip_z_right"     gear="40"  joint="hip_z_right"/>
    <motor name="hip_y_right"     gear="120" joint="hip_y_right"/>
    <motor name="knee_right"      gear="80"  joint="knee_right"/>
    <motor name="ankle_y_right"   gear="20"  joint="ankle_y_right"/>
    <motor name="ankle_x_right"   gear="20"  joint="ankle_x_right"/>
    <motor name="hip_x_left"      gear="40"  joint="hip_x_left"/>
    <motor name="hip_z_left"      gear="40"  joint="hip_z_left"/>
    <motor name="hip_y_left"      gear="120" joint="hip_y_left"/>
    <motor name="knee_left"       gear="80"  joint="knee_left"/>
    <motor name="ankle_y_left"    gear="20"  joint="ankle_y_left"/>
    <motor name="ankle_x_left"    gear="20"  joint="ankle_x_left"/>
    <motor name="shoulder1_right" gear="20"  joint="shoulder1_right"/>
    <motor name="shoulder2_right" gear="20"  joint="shoulder2_right"/>
    <motor name="shoulder3_right" gear="20"  joint="shoulder3_right"/>
    <motor name="elbow_right"     gear="40"  joint="elbow_right"/>
    <motor name="shoulder1_left"  gear="20"  joint="shoulder1_left"/>
    <motor name="shoulder2_left"  gear="20"  joint="shoulder2_left"/>
    <motor name="shoulder3_left"  gear="20"  joint="shoulder3_left"/>
    <motor name="elbow_left"      gear="40"  joint="elbow_left"/>
  </actuator>

  <keyframe>
    <key name="drop_impact"
        qpos="0 0 1.60
            0.988015 0 0.154359 0
            0 0.4 0
            -0.25 -0.5 -2.5 -2.65 -0.8 0.56 0
            -0.25 -0.5 -2.5 -2.65 -0.8 0.56 0
            0 0 0 0
            0 0 0 0"/>
  </keyframe>
</mujoco>